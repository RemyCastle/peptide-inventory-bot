# Required: from @BotFather (primary / legacy single token)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Optional standby pool (different Telegram accounts OK). Comma-separated.
# When the active token is banned/invalid, TOKEN_FAILOVER advances to the next.
# BOT_TOKENS=token_account_A,token_account_B,token_account_C
# ACTIVE_BOT_INDEX=0
# TOKEN_FAILOVER=1
# TOKEN_STATE_PATH=token_state.json

# Comma-separated Telegram user IDs that are global owners
# Get your ID from @userinfobot
OWNER_IDS=123456789

# Instance branding defaults (per-shop overrides live in DB / admin later)
BRAND_NAME=UnicornFartzzBot
CURRENCY=USD
CURRENCY_SYMBOL=$
WELCOME_TEXT=Browse the catalog, add items to your cart, and checkout when ready.

# Default shipping when a new shop is created
DEFAULT_SHIPPING_FEE=8.00
DEFAULT_FREE_SHIPPING_ABOVE=150.00

# Alert admins when stock is at or below this after a paid confirm
DEFAULT_LOW_STOCK_THRESHOLD=2

# Encrypted inventory vault (live DB stays separate). Required for auto snapshots.
# BACKUP_PASSPHRASE=long-random-secret-in-password-manager-only
# BACKUP_DIR=backups
# BACKUP_RETENTION_DAYS=30

# Optional public pointer after cutover
# PUBLIC_BOT_USERNAME=YourBotUsername
# RECOVERY_URL=https://yoursite.example/

# Optional paths
# DB_PATH=C:\Users\Remy\peptide_inventory_bot\inventory.db
# LOG_PATH=C:\Users\Remy\peptide_inventory_bot\bot.log
