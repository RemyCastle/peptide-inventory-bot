# Required: from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Comma-separated Telegram user IDs that are global owners
# Get your ID from @userinfobot
OWNER_IDS=123456789

# Instance branding defaults (per-shop overrides live in DB / admin later)
BRAND_NAME=UnicornFartzzBot
CURRENCY=USD
CURRENCY_SYMBOL=$
WELCOME_TEXT=Browse the catalog, add items to your cart, and checkout when ready.

# Default shipping when a new shop is created
DEFAULT_SHIPPING_FEE=8.00
DEFAULT_FREE_SHIPPING_ABOVE=150.00

# Alert admins when stock is at or below this after a paid confirm
DEFAULT_LOW_STOCK_THRESHOLD=2

